# ═══════════════════════════════════════════════════════════════════════════════
# Digital FTE for HR — Local Environment Variables Template
# Copy: cp .env.local.example .env.local
# Then fill in all YOUR actual values
# NEVER commit .env.local to git — it is in .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# ══════════════════════════════════════════════════════════════════════════════
# 🤖 MCP (MODEL CONTEXT PROTOCOL) SERVERS - Claude Code Integration
# ══════════════════════════════════════════════════════════════════════════════
# These enable Claude Code to access GitHub, PostgreSQL, files, AWS, Playwright

# ── Anthropic API (Claude Code + LLM calls) ──────────────────────────────────
# Get from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-your-actual-api-key-here

# ── GitHub MCP ─────────────────────────────────────────────────────────────────
# Purpose: Create/manage issues, PRs, check CI status, search code
# Get token: https://github.com/settings/tokens?type=beta
# Scopes: repo (full), workflow, read:org
GITHUB_PERSONAL_ACCESS_TOKEN=github_pat_your_token_here

# ── PostgreSQL MCP ─────────────────────────────────────────────────────────────
# Purpose: Query database, inspect schemas, debug migrations
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
#
# Option 1: Local Docker (recommended for dev)
# postgresql://postgres:password@localhost:5432/digitalfte_dev
#
# Option 2: AWS RDS
# postgresql://admin:password@digital-fte.xxxxx.rds.amazonaws.com:5432/digitalfte_dev
#
# Option 3: Cloud database (Render, Supabase, etc.)
# postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/digitalfte_dev

# ── AWS MCP ────────────────────────────────────────────────────────────────────
# Purpose: Deploy CDK stacks, read Lambda logs, inspect SQS, S3 operations
# Create IAM user: https://console.aws.amazon.com/iam/
# User: claude-code-dev
# Permissions: AdministratorAccess (dev) or:
#   - AWSCloudFormationFullAccess (CDK)
#   - AmazonEC2FullAccess
#   - AmazonSQSFullAccess
#   - AmazonS3FullAccess
#   - CloudWatchLogsReadOnlyAccess
AWS_ACCESS_KEY_ID=AKIA_your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
AWS_REGION=us-east-1

# ── Playwright MCP ─────────────────────────────────────────────────────────────
# Purpose: Browser automation, test form handlers, debug UI
# No configuration needed - Playwright auto-manages browsers
# First run will download browsers (2-3 minutes)
PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=false

# ── Memory MCP ─────────────────────────────────────────────────────────────────
# Purpose: Store architectural decisions, track progress across sessions
# No configuration needed - fully local, no setup required

# ══════════════════════════════════════════════════════════════════════════════
# 📱 APPLICATION SERVICES
# ══════════════════════════════════════════════════════════════════════════════

# ── Node Environment ──────────────────────────────────────────────────────────
NODE_ENV=development
ENVIRONMENT=dev

# ── WhatsApp (Twilio) ──────────────────────────────────────────────────────────
# Get from: https://www.twilio.com/console
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── Telegram Bot Integration ──────────────────────────────────────────────────
# Create bot: message @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGhIjKlmNoPqRsTuVwXyZ

# ── Amazon Cognito (User Authentication) ──────────────────────────────────────
# Get from: https://console.aws.amazon.com/cognito/
# Pool ID: us-west-2_xxxxxxxxx
# Client ID: xxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_USER_POOL_ID=us-west-2_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_CLIENT_SECRET=your_cognito_client_secret

# ── Redis (Queue + Caching) ───────────────────────────────────────────────────
# Local: redis://localhost:6379
# ElastiCache: redis://digital-fte.xxxxx.ng.0001.use1.cache.amazonaws.com:6379
REDIS_URL=redis://localhost:6379

# ── Amazon SES (Email Notifications) ──────────────────────────────────────────
SES_FROM_EMAIL=noreply@yourdomain.com
SES_FROM_NAME=Digital FTE
SES_REGION=us-east-1

# ── Amazon S3 (File Storage) ──────────────────────────────────────────────────
# Create S3 buckets: digital-fte-resumes-dev, digital-fte-screenshots-dev
S3_BUCKET_RESUMES=digital-fte-resumes-dev
S3_BUCKET_SCREENSHOTS=digital-fte-screenshots-dev
S3_REGION=us-east-1

# ── OpenSearch (Serverless Vector Database) ───────────────────────────────────
# Get from: https://console.aws.amazon.com/opensearchserverless/
OPENSEARCH_ENDPOINT=https://your-collection-id.us-east-1.aoss.amazonaws.com

# ── Stripe (Payment Processing) ────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/
# Keys are in Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# ══════════════════════════════════════════════════════════════════════════════
# 🌐 API & FRONTEND CONFIGURATION
# ══════════════════════════════════════════════════════════════════════════════

# ── REST API Configuration ────────────────────────────────────────────────────
# Backend API base URL (where apps/api is running)
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# ── NextAuth.js (Frontend Authentication) ─────────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=your-secret-key-generate-with-openssl-rand-base64-32

# ── Feature Flags ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_DEBUG_MODE=false

# ══════════════════════════════════════════════════════════════════════════════
# 📋 IMPORTANT NOTES
# ══════════════════════════════════════════════════════════════════════════════

# ✅ Quick Setup Steps:
# 1. cp .env.local.example .env.local
# 2. Fill in the placeholders above with your actual credentials
# 3. For MCP servers, follow: https://github.com/Faisal407/digital-fte-hr/blob/main/MCP_SETUP_GUIDE.md
# 4. Start Claude Code: claude-code
#
# ⚠️ Security:
# • NEVER commit .env.local to git
# • Never share your credentials
# • Rotate API keys quarterly
# • Use IAM roles instead of access keys in production
#
# 🔗 Documentation:
# • MCP Setup: See MCP_SETUP_GUIDE.md
# • Vercel Deployment: See VERCEL_QUICKSTART.md
# • Full Deployment: See DEPLOYMENT.md
