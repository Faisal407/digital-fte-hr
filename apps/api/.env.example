# Server
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/digital_fte_dev?schema=public"

# Redis (for rate limiting in production)
REDIS_URL="redis://localhost:6379"

# CORS
CORS_ORIGIN="http://localhost:3000"

# Cognito (for production)
COGNITO_USER_POOL_ID=us-east-1_xxxxx
COGNITO_CLIENT_ID=xxxxx
COGNITO_REGION=us-east-1

# AWS
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789

# API Gateway
API_GATEWAY_STAGE=dev

# Tables
AUDIT_LOG_TABLE=audit_logs

# Secrets (use AWS Secrets Manager in production)
# ANTHROPIC_API_KEY=sk-ant-...
# TWILIO_AUTH_TOKEN=...
# TELEGRAM_BOT_TOKEN=...
