# ═══════════════════════════════════════════════════════════════════════════════
# Digital FTE for HR — Web App Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# ── NextAuth (Frontend Authentication) ─────────────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=your-secret-key-generate-with-openssl-rand-base64-32

# ── API Configuration ──────────────────────────────────────────────────────────
# Backend API base URL (where REST API is running)
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_DEBUG_MODE=false

# ── AWS Cognito (Authentication Provider) ──────────────────────────────────────
# Get from AWS Cognito console
AWS_COGNITO_CLIENT_ID=your-cognito-client-id
AWS_COGNITO_CLIENT_SECRET=your-cognito-client-secret
AWS_COGNITO_ISSUER=https://cognito-idp.us-west-2.amazonaws.com/{pool-id}
