{
  "name": "digital-fte-hr",
  "version": "1.0.0",
  "description": "Digital Full-Time Employee for HR - AI-powered job search & resume optimization",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    "services/*",
    "infra"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r --parallel build",
    "test": "pnpm -r test",
    "test:ci": "pnpm -r test:ci",
    "test:unit": "pnpm -r test:unit",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome lint .",
    "format": "biome format .",
    "db:migrate": "pnpm --filter db migrate",
    "db:push": "pnpm --filter db push",
    "db:studio": "pnpm --filter db studio",
    "db:seed": "pnpm --filter db seed",
    "install:all": "pnpm install"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=8.0.0"
  }
}
