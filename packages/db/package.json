{
  "name": "@packages/db",
  "version": "1.0.0",
  "description": "Database schema and Prisma client",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./dist/index.js",
    "./client": "./dist/client.js",
    "./gdpr": "./dist/gdpr-registry.js"
  },
  "main": "dist/index.js",
  "files": ["dist", "prisma"],
  "scripts": {
    "build": "tsc --declaration",
    "dev": "tsc --declaration --watch",
    "typecheck": "tsc --noEmit",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "generate": "prisma generate",
    "push": "prisma db push --skip-generate",
    "studio": "prisma studio",
    "seed": "node --loader ts-node/esm prisma/seed.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "prisma": "^5.10.0",
    "typescript": "^5.3.3"
  },
  "prisma": {
    "seed": "node --loader ts-node/esm prisma/seed.ts"
  }
}
