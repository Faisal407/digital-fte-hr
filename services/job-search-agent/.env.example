# Environment
NODE_ENV=development
LOG_LEVEL=INFO

# Anthropic API (for Claude scoring & dedup)
ANTHROPIC_API_KEY=sk-ant-...

# Redis (for rate limiting)
REDIS_URL=redis://localhost:6379

# AWS
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789

# SQS (if running as worker)
JOB_SEARCH_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/job-search-tasks

# Rate Limiting
RATE_LIMIT_PER_HOUR=100
SEARCH_DELAY_MS=100

# Platform API Keys (optional)
LINKEDIN_ACCESS_TOKEN=
INDEED_API_KEY=

# Playwright
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000

# Job Search Config
MIN_MATCH_SCORE=30
DEDUP_CONFIDENCE_THRESHOLD=0.7
GHOST_JOB_CONFIDENCE_THRESHOLD=0.6
