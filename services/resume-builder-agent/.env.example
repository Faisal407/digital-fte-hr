# Resume Builder Agent Configuration

# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# AWS Configuration (for S3 output storage)
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# Resume Builder Settings
RESUME_OUTPUT_DIR=/tmp/resumes
MAX_RESUME_SIZE_MB=10

# Export Settings
EXPORT_FORMATS=txt,pdf,docx
ENABLE_S3_EXPORT=false

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# LangGraph Settings
LANGGRAPH_RECURSION_LIMIT=100
